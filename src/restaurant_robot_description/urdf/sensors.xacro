<?xml version="1.0"?>
<!--
  sensors.xacro
  Package: restaurant_robot_description
  Description: Sensor link definitions for the restaurant robot.
               - 2D LiDAR mounted on top of chassis
  ROS Version: ROS 2 Jazzy Jalisco
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- LIDAR — on top of chassis -->
    <joint name="laser_joint" type="fixed">
        <parent link="chassis_link"/>
        <child link="laser_frame"/>
        <!-- Chassis top is at Z=0.07. LIDAR X=130mm from rear edge. -->
        <origin xyz="0.130 0 0.090" rpy="0 0 0"/>
    </joint>
    <gazebo reference="laser_joint">
        <preserveFixedJoint>true</preserveFixedJoint>
    </gazebo>
    <link name="laser_frame">
        <visual>
            <origin xyz="0 0 -0.010" rpy="0 0 0"/>
            <geometry><cylinder radius="0.035" length="0.020"/></geometry>
            <material name="white"/>
        </visual>
        <visual>
            <origin xyz="0 0 0.008" rpy="0 0 0"/>
            <geometry><cylinder radius="0.032" length="0.018"/></geometry>
            <material name=""><color rgba="0.1 0.1 0.3 1.0"/></material>
        </visual>
        <collision>
            <geometry><cylinder radius="0.035" length="0.040"/></geometry>
        </collision>
        <inertial>
            <mass value="0.17"/>
            <inertia ixx="7.5e-5" ixy="0" ixz="0" iyy="7.5e-5" iyz="0" izz="1.04e-4"/>
        </inertial>
    </link>
    <gazebo reference="laser_frame">
        <material>
            <ambient>0.1 0.1 0.3 1</ambient>
            <diffuse>0.1 0.1 0.3 1</diffuse>
        </material>
    </gazebo>

    <!-- IMU — inside chassis -->
    <joint name="imu_joint" type="fixed">
        <parent link="chassis_link"/>
        <child link="imu_link"/>
        <!-- Placed safely in the center of the 0.07m height chassis -->
        <origin xyz="0.10 0 0.035" rpy="0 0 0"/>
    </joint>
    <gazebo reference="imu_joint">
        <preserveFixedJoint>true</preserveFixedJoint>
    </gazebo>
    <link name="imu_link">
        <visual>
            <geometry><box size="0.020 0.020 0.005"/></geometry>
            <material name=""><color rgba="0.0 0.5 0.0 1.0"/></material>
        </visual>
        <inertial>
            <mass value="0.01"/>
            <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
        </inertial>
    </link>

</robot>
