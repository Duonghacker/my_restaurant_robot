<?xml version="1.0"?>
<!--
  robot_core.xacro
  Package: restaurant_robot_description
  Description: Mechanical structure of the restaurant service robot.
               Matches the reference design:
                 - Rectangular chassis: 300 x 300 x 150 mm
                 - 2 rear drive wheels: 100mm diameter, 40mm wide, 350mm separation
                 - 1 front caster wheel: 50mm diameter
                 - chassis_joint origin at (-0.1, 0, 0)
                
  Coordinate Convention (ROS standard):
    X = forward, Y = left, Z = up
    base_link is at the center of the rear drive axle, at wheel center height
    
  ROS Version: ROS 2 Jazzy Jalisco
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Include inertia calculation macros -->
    <xacro:include filename="$(find restaurant_robot_description)/urdf/inertia_macros.xacro"/>

    <!-- ============================================================
         PHYSICAL PARAMETERS (from reference design)
         All dimensions in meters, mass in kg
         ============================================================ -->
    
    <!-- Chassis dimensions -->
    <xacro:property name="chassis_length" value="0.20"/>
    <xacro:property name="chassis_width"  value="0.19"/>
    <xacro:property name="chassis_height" value="0.07"/>
    <xacro:property name="chassis_mass"   value="0.5"/>
    
    <!-- Drive wheel parameters -->
    <xacro:property name="wheel_radius"     value="0.0325"/>
    <xacro:property name="wheel_width"      value="0.026"/>
    <xacro:property name="wheel_mass"       value="0.1"/>
    <xacro:property name="wheel_separation" value="0.220"/>
    
    <!-- Caster wheel parameters -->
    <xacro:property name="caster_radius" value="0.0165"/>
    <xacro:property name="caster_mass"   value="0.1"/>

    <!-- ============================================================
         COLOR DEFINITIONS
         ============================================================ -->
    <material name="white">
        <color rgba="1 1 1 1"/>
    </material>
    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>
    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>
    <material name="green">
        <color rgba="0 1 0 1"/>
    </material>
    <material name="blue">
        <color rgba="0 0 1 1"/>
    </material>

    <!-- ============================================================
         BASE FOOTPRINT — Ground projection of drive axle center
         This is the "zero" frame for navigation. Sits on the ground.
         ============================================================ -->
    <link name="base_footprint">
        <inertial>
            <mass value="1e-5"/>
            <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
        </inertial>
    </link>

    <!-- ============================================================
         BASE LINK — Reference frame at drive axle center height
         Fixed joint from base_footprint, raised by wheel_radius
         ============================================================ -->
    <joint name="base_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
    </joint>
    <gazebo reference="base_joint">
        <preserveFixedJoint>true</preserveFixedJoint>
    </gazebo>

    <link name="base_link">
        <inertial>
            <mass value="1e-5"/>
            <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
        </inertial>
    </link>

    <!-- ============================================================
         CHASSIS LINK — Main robot body
         Rectangular box: 200 x 190 x 70 mm
         chassis_joint origin at (-0.067, 0, 0) matching physical motor axle
         Visual origin at (0.10, 0, 0.035) relative to chassis_link
         ============================================================ -->
    <joint name="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis_link"/>
        <origin xyz="-0.067 0 0" rpy="0 0 0"/>
    </joint>
    <gazebo reference="chassis_joint">
        <preserveFixedJoint>true</preserveFixedJoint>
    </gazebo>

    <link name="chassis_link">
        <visual>
            <origin xyz="0.10 0 0.035"/>
            <geometry>
                <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <origin xyz="0.10 0 0.035"/>
            <geometry>
                <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass="${chassis_mass}" x="${chassis_length}" y="${chassis_width}" z="${chassis_height}">
            <origin xyz="0.10 0 0.035" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <!-- Gazebo visual material for chassis -->
    <gazebo reference="chassis_link">
        <material>
            <ambient>1 1 1 1</ambient>
            <diffuse>1 1 1 1</diffuse>
            <specular>1 1 1 1</specular>
        </material>
    </gazebo>

    <!-- ============================================================
         LEFT DRIVE WHEEL
         Continuous joint, rotating around Z after -90° Y rotation
         Position: at base_link, offset left by wheel_separation/2 (0.175)
         ============================================================ -->
    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="0 ${wheel_separation/2} 0" rpy="-${pi/2} 0 0"/>
        <axis xyz="0 0 1"/>
        <dynamics damping="0.01" friction="0.1"/>
        <limit effort="5.0" velocity="20.0"/>
    </joint>

    <link name="left_wheel">
        <visual>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="${wheel_mass}" radius="${wheel_radius}" length="${wheel_width}">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <!-- Drive wheel surface friction (high grip for traction) -->
    <gazebo reference="left_wheel">
        <material>
            <ambient>0 0 1 1</ambient>
            <diffuse>0 0 1 1</diffuse>
        </material>
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>1.0</mu>
                        <mu2>1.0</mu2>
                        <slip1>0.0</slip1>
                        <slip2>0.0</slip2>
                        <fdir1>0 0 1</fdir1>
                    </ode>
                </friction>
                <contact>
                    <ode>
                        <kp>1e6</kp>
                        <kd>100</kd>
                        <min_depth>0.001</min_depth>
                    </ode>
                </contact>
            </surface>
        </collision>
    </gazebo>

    <!-- ============================================================
         RIGHT DRIVE WHEEL
         Mirror of left wheel on the opposite side
         ============================================================ -->
    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="0 -${wheel_separation/2} 0" rpy="${pi/2} 0 0"/>
        <axis xyz="0 0 -1"/>
        <dynamics damping="0.01" friction="0.1"/>
        <limit effort="5.0" velocity="20.0"/>
    </joint>

    <link name="right_wheel">
        <visual>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="${wheel_mass}" radius="${wheel_radius}" length="${wheel_width}">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <!-- Drive wheel surface friction (high grip for traction) -->
    <gazebo reference="right_wheel">
        <material>
            <ambient>0 0 1 1</ambient>
            <diffuse>0 0 1 1</diffuse>
        </material>
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>1.0</mu>
                        <mu2>1.0</mu2>
                        <slip1>0.0</slip1>
                        <slip2>0.0</slip2>
                        <fdir1>0 0 1</fdir1>
                    </ode>
                </friction>
                <contact>
                    <ode>
                        <kp>1e6</kp>
                        <kd>100</kd>
                        <min_depth>0.001</min_depth>
                    </ode>
                </contact>
            </surface>
        </collision>
    </gazebo>

    <!-- ============================================================
         FRONT CASTER WHEEL
         Fixed joint (modeled as frictionless sphere)
         Position: 0.16m forward from chassis_link origin (rear edge)
         Z-offset: dropped to touch the ground
         ============================================================ -->
    <joint name="caster_joint" type="fixed">
        <parent link="chassis_link"/>
        <child link="caster_wheel"/>
        <origin xyz="0.160 0 -0.016"/>
    </joint>

    <link name="caster_wheel">
        <visual>
            <geometry>
                <sphere radius="${caster_radius}"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="${caster_radius}"/>
            </geometry>
        </collision>
        <xacro:inertial_sphere mass="${caster_mass}" radius="${caster_radius}">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <!-- Caster wheel: near-zero friction for free rolling -->
    <gazebo reference="caster_wheel">
        <material>
            <ambient>0 0 0 1</ambient>
            <diffuse>0 0 0 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
        </material>
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>0.001</mu>
                        <mu2>0.001</mu2>
                        <slip1>1.0</slip1>
                        <slip2>1.0</slip2>
                    </ode>
                </friction>
                <contact>
                    <ode>
                        <kp>1e6</kp>
                        <kd>100</kd>
                        <min_depth>0.001</min_depth>
                    </ode>
                </contact>
            </surface>
        </collision>
    </gazebo>

</robot>
